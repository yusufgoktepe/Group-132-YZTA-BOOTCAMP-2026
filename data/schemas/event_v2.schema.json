{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campusmatch.event.v2",
  "title": "CampusMatch Event V2",
  "type": "object",
  "required": [
    "event_id",
    "club_id",
    "university_id",
    "title",
    "description",
    "category_id",
    "interest_ids",
    "event_type",
    "starts_at",
    "participation_mode",
    "fee_type",
    "language",
    "status"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "club_id": { "type": "string" },
    "university_id": { "type": "string" },
    "campus_id": { "type": ["string", "null"] },
    "title": { "type": "string", "minLength": 3 },
    "description": { "type": "string", "minLength": 10 },
    "category_id": { "type": "string" },
    "interest_ids": { "type": "array", "items": { "type": "string" } },
    "target_program_ids": { "type": "array", "items": { "type": "string" } },
    "target_goal_ids": { "type": "array", "items": { "type": "string" } },
    "event_type": { "type": "string" },
    "starts_at": { "type": "string", "format": "date-time" },
    "ends_at": { "type": ["string", "null"], "format": "date-time" },
    "participation_mode": { "enum": ["onsite", "online", "hybrid"] },
    "location_name": { "type": ["string", "null"] },
    "fee_type": { "enum": ["free", "paid"] },
    "fee_amount": { "type": ["number", "null"], "minimum": 0 },
    "quota": { "type": ["integer", "null"], "minimum": 1 },
    "language": { "enum": ["tr", "en", "mixed"] },
    "application_deadline": { "type": ["string", "null"], "format": "date-time" },
    "status": { "enum": ["draft", "published", "full", "cancelled", "completed"] },
    "image_url": { "type": ["string", "null"] }
  }
}
