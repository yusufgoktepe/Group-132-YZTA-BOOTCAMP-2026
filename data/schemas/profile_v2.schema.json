{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campusmatch.profile.v2",
  "title": "CampusMatch Student Profile V2",
  "type": "object",
  "required": [
    "schema_version",
    "education_reference_version",
    "university_id",
    "program_id",
    "education_level",
    "class_year",
    "interest_ids",
    "participation_goal_ids",
    "participation_modes",
    "fee_preference",
    "language_preference"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "education_reference_version": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "maxLength": 80 },
    "university_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "education_level": { "enum": ["associate", "bachelor", "master", "doctorate"] },
    "class_year": { "type": "string", "pattern": "^(prep|[1-6])$" },
    "interest_ids": {
      "type": "array",
      "minItems": 3,
      "maxItems": 10,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "participation_goal_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "participation_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["onsite", "online", "hybrid"] }
    },
    "fee_preference": { "enum": ["free_only", "paid_ok", "no_preference"] },
    "language_preference": { "enum": ["tr", "en", "no_preference"] },
    "campus_id": { "type": ["string", "null"] },
    "accessibility_needs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  }
}
